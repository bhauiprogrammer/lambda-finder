{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lambda Finder",
  "version": "1.0.0",
  "identifier": "com.utec.lambdafinder.v2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lambda Finder",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0f172a"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bhauiprogrammer/lambda-finder/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2REE3OUE2MjIyN0RCNUEKUldSYTJ5Y2lwbm5hVmlFVEhqNTJIbUk4S2xLVFNxWUJyTkxnQyt3NGJJV0NDVWVDMVd5aFBHU3UK"
    }
  }
}
